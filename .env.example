# Chatwoot CE + AI bot — example env. Copy to `.env` and fill in
# secrets. Generate fresh values for SECRET_KEY_BASE, POSTGRES_PASSWORD,
# REDIS_PASSWORD, VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY (see README).

# ============================================================
# Rails core
# ============================================================
SECRET_KEY_BASE=__GENERATE_64_HEX_BYTES__
NODE_ENV=production
RAILS_ENV=production
INSTALLATION_ENV=docker
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
RAILS_MAX_THREADS=5

# URL agents and end-users see in emails + the widget script.
FRONTEND_URL=https://chat.example.com
DEFAULT_LOCALE=et

# Traefik handles TLS termination at the edge. FORCE_SSL=true makes Rails
# 301-redirect non-HTTPS requests (it doesn't trust the proxy's
# X-Forwarded-Proto by default) — which breaks ActionCable WebSocket
# upgrades. Leave FALSE; Traefik enforces HTTPS already.
FORCE_SSL=false
ENABLE_ACCOUNT_SIGNUP=false
DISABLE_TELEMETRY=true

INSTALLATION_NAME=Veebist Chat
DIRECT_UPLOADS_ENABLED=false

# ============================================================
# Database — dedicated to this stack
# ============================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=__GENERATE_24_BYTES_BASE64__

# ============================================================
# Redis — dedicated to this stack, password-protected
# ============================================================
REDIS_PASSWORD=__GENERATE_24_BYTES_BASE64__
REDIS_URL=redis://:__SAME_AS_REDIS_PASSWORD__@redis:6379

# ============================================================
# Outgoing email (transactional: password resets, notifications)
# ============================================================
MAILER_SENDER_EMAIL=hello@example.com
SMTP_DOMAIN=example.com
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=hello@example.com
SMTP_PASSWORD=__SMTP_PASSWORD__
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=false
SMTP_TLS=true
SMTP_OPENSSL_VERIFY_MODE=peer

# ============================================================
# Storage — disk-backed (volume mounted at /app/storage)
# ============================================================
ACTIVE_STORAGE_SERVICE=local

# ============================================================
# Bot (Claude-CLI-backed AI assistant)
# After registering the first admin user in Chatwoot:
#   Profile → Access Token  (personal admin token)
#   Settings → Integrations → Agent Bots → New  (creates an Agent Bot
#     with its own access token — prefer this so messages are signed
#     as "ScottEst AI" not your name)
# ============================================================
BOT_CHATWOOT_API_TOKEN=__PASTE_AFTER_FIRST_LOGIN__
BOT_CHATWOOT_ACCOUNT_ID=1

# LLM providers — primary tried first; secondary on failure. Values:
# claude | codex | none. Note Codex on this host needs the symlink fix
# documented in memory chatwoot-stack.md (v0.132.0, NOT /usr/local).
PRIMARY_LLM=claude
SECONDARY_LLM=codex
MAX_CONCURRENT=6

# Failover alerts — set ALERT_INBOX_ID to the Chatwoot inbox you want
# alerts to post into (visible in the mobile app); ALERT_CONTACT_ID to a
# contact id to associate them with. Leave blank to disable Chatwoot alerts.
# Email alerts: leave ALERT_SMTP_HOST blank to disable.
ALERT_INBOX_ID=
ALERT_CONTACT_ID=
ALERT_SMTP_HOST=smtp.hostinger.com
ALERT_SMTP_PORT=465
ALERT_SMTP_SECURE=true
ALERT_SMTP_USER=info@scottest.ee
ALERT_SMTP_PASS=
ALERT_EMAIL_FROM=info@scottest.ee
ALERT_EMAIL_TO=tarmo@veebist.ee

# OpenAI-compatible shim — set this to a strong random secret, then in
# Chatwoot admin (Settings → Integrations → OpenAI) paste the SAME value
# as the "OpenAI API key". Leave blank to disable the endpoint.
# Also: set OPENAI_API_BASE_URL on the chatwoot-rails/sidekiq containers
# to https://chat-bot.veebist.cloud/v1
CHATWOOT_OPENAI_KEY=

# Generic /api/chat endpoint — bearer token for external Veebist tools
# (internal services, mobile app, etc.). Leave blank to disable.
CHAT_BOT_API_TOKEN=

# ============================================================
# Per-site live catalog (Phase 1 — Medusa + Payload)
# Snapshot is rebuilt every 10 min (stale-while-revalidate up to 1h).
# Add a new block per onboarded site; site key maps via bot/site-config.js.
# ============================================================
SCOTTEST_MEDUSA_URL=https://scottest.veebist.cloud/medusa
SCOTTEST_MEDUSA_PUBLISHABLE_KEY=pk_d19eb9af84c7ba54659e5c982ed20e75e31f3b859c27849614f9dddee2ae5ccc
SCOTTEST_PAYLOAD_URL=https://scottest.veebist.cloud/api
# SCOTTEST_PAYLOAD_TOKEN=          # optional, only for non-public reads
# SCOTTEST_PRODUCT_LIMIT=100       # default 100
# SCOTTEST_ARTICLE_LIMIT=10        # default 10
# SCOTTEST_MEDUSA_REGION_ID=       # auto-detected if blank

# ============================================================
# Push notifications (mobile + browser)
# Generate VAPID keys:
#   docker exec chatwoot-rails bundle exec ruby -e \
#     'require "web-push"; k = WebPush.generate_key; \
#      puts "PUB=" + k.public_key; puts "PRIV=" + k.private_key'
# ============================================================
ENABLE_PUSH_RELAY_SERVER=true
VAPID_PUBLIC_KEY=__FROM_GENERATE_COMMAND__
VAPID_PRIVATE_KEY=__FROM_GENERATE_COMMAND__
